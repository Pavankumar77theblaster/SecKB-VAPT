# Security Pipeline — Environment Variables
# Copy this file to .env and fill in your real keys
# Never commit .env to git

# ── AI APIs ──────────────────────────────────────────────────────────────────
# Free at: https://console.groq.com/keys
GROQ_API_KEY=xxxx

# Free at: https://aistudio.google.com/apikey  (required for Labs feature)
GEMINI_API_KEY=xxxx

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_TOKEN=xxxx

# ── Optional Integrations ────────────────────────────────────────────────────
# Google Sheets ID (from URL: .../spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEETS_ID=xxxx

# Obsidian vault export path
OBSIDIAN_VAULT=/home/YOUR_USER/SecurityKB
